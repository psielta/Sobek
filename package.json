{
  "name": "sobek",
  "displayName": "Sobek",
  "description": "Prompt engineering workbench for AI coding agents: versioned Markdown prompts, child prompt generation, kanban workflow and agent terminals bound to your workspace.",
  "version": "0.1.0",
  "publisher": "psielta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/psielta/Sobek.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "prompt",
    "prompt-engineering",
    "claude",
    "codex",
    "gemini",
    "kanban",
    "agents"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sobek",
          "title": "Sobek",
          "icon": "media/sobek.svg"
        }
      ]
    },
    "views": {
      "sobek": [
        {
          "id": "sobekPrompts",
          "name": "Prompts",
          "icon": "media/sobek.svg",
          "contextualTitle": "Sobek: Prompts"
        },
        {
          "id": "sobekAssistant",
          "type": "webview",
          "name": "Assistente IA",
          "icon": "media/sobek.svg",
          "contextualTitle": "Sobek: IA"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sobekPrompts",
        "contents": "Nenhum prompt neste workspace ainda.\n[Criar prompt](command:sobek.createPrompt)\nOs prompts ficam versionados em `.sobek/` na raiz do workspace.",
        "when": "sobek.hasWorkspace"
      },
      {
        "view": "sobekPrompts",
        "contents": "Abra uma pasta para usar o Sobek: o workspace aberto é o diretório alvo dos prompts.",
        "when": "!sobek.hasWorkspace"
      }
    ],
    "commands": [
      {
        "command": "sobek.createPrompt",
        "title": "Novo prompt",
        "category": "Sobek",
        "icon": "$(add)"
      },
      {
        "command": "sobek.refreshPrompts",
        "title": "Recarregar prompts",
        "category": "Sobek",
        "icon": "$(refresh)"
      },
      {
        "command": "sobek.openPrompt",
        "title": "Abrir prompt",
        "category": "Sobek"
      },
      {
        "command": "sobek.openChildPrompt",
        "title": "Abrir prompt filho",
        "category": "Sobek"
      },
      {
        "command": "sobek.copyPromptContent",
        "title": "Copiar prompt",
        "category": "Sobek",
        "icon": "$(copy)"
      },
      {
        "command": "sobek.renamePrompt",
        "title": "Renomear prompt",
        "category": "Sobek"
      },
      {
        "command": "sobek.setPromptStatus",
        "title": "Alterar status",
        "category": "Sobek"
      },
      {
        "command": "sobek.setTargetAgent",
        "title": "Alterar agente alvo",
        "category": "Sobek"
      },
      {
        "command": "sobek.archivePrompt",
        "title": "Arquivar prompt",
        "category": "Sobek",
        "icon": "$(archive)"
      },
      {
        "command": "sobek.deletePrompt",
        "title": "Excluir prompt",
        "category": "Sobek"
      },
      {
        "command": "sobek.showPromptVersions",
        "title": "Histórico de versões",
        "category": "Sobek",
        "icon": "$(history)"
      },
      {
        "command": "sobek.generateChildPrompt",
        "title": "Gerar prompt filho",
        "category": "Sobek",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "sobek.linkPlan",
        "title": "Vincular plano Markdown",
        "category": "Sobek",
        "icon": "$(link)"
      },
      {
        "command": "sobek.unlinkPlan",
        "title": "Desvincular plano",
        "category": "Sobek"
      },
      {
        "command": "sobek.newPromptTerminal",
        "title": "Novo terminal do prompt",
        "category": "Sobek",
        "icon": "$(terminal)"
      },
      {
        "command": "sobek.launchAgentTerminal",
        "title": "Iniciar agente no terminal",
        "category": "Sobek",
        "icon": "$(robot)"
      },
      {
        "command": "sobek.runPromptInAgentTerminal",
        "title": "Executar prompt no agente",
        "category": "Sobek",
        "icon": "$(play)"
      },
      {
        "command": "sobek.newWorkspaceTerminal",
        "title": "Novo terminal no workspace",
        "category": "Sobek"
      },
      {
        "command": "sobek.openBoard",
        "title": "Abrir board de tarefas",
        "category": "Sobek",
        "icon": "$(layout-panel-justify)"
      },
      {
        "command": "sobek.startWorkflow",
        "title": "Iniciar fluxo da tarefa",
        "category": "Sobek"
      },
      {
        "command": "sobek.addWorkflowNote",
        "title": "Adicionar nota na timeline",
        "category": "Sobek"
      },
      {
        "command": "sobek.addReviewVerdict",
        "title": "Adicionar veredito de revisão",
        "category": "Sobek"
      },
      {
        "command": "sobek.changeWorkflowActor",
        "title": "Trocar responsável da tarefa",
        "category": "Sobek"
      },
      {
        "command": "sobek.completeWorkflow",
        "title": "Concluir tarefa",
        "category": "Sobek"
      },
      {
        "command": "sobek.reopenWorkflow",
        "title": "Reabrir tarefa",
        "category": "Sobek"
      },
      {
        "command": "sobek.showTimeline",
        "title": "Ver timeline da tarefa",
        "category": "Sobek",
        "icon": "$(list-ordered)"
      },
      {
        "command": "sobek.refinePrompt",
        "title": "Refinar prompt com Gemini",
        "category": "Sobek",
        "icon": "$(sparkle)"
      },
      {
        "command": "sobek.setGeminiApiKey",
        "title": "Configurar chave Gemini",
        "category": "Sobek"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sobek.createPrompt",
          "when": "view == sobekPrompts",
          "group": "navigation@1"
        },
        {
          "command": "sobek.openBoard",
          "when": "view == sobekPrompts",
          "group": "navigation@2"
        },
        {
          "command": "sobek.refreshPrompts",
          "when": "view == sobekPrompts",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "sobek.copyPromptContent",
          "when": "view == sobekPrompts",
          "group": "inline@1"
        },
        {
          "command": "sobek.generateChildPrompt",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "0_generate@1"
        },
        {
          "command": "sobek.linkPlan",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "0_generate@2"
        },
        {
          "command": "sobek.unlinkPlan",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "0_generate@3"
        },
        {
          "command": "sobek.renamePrompt",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "1_edit@1"
        },
        {
          "command": "sobek.setPromptStatus",
          "when": "view == sobekPrompts",
          "group": "1_edit@2"
        },
        {
          "command": "sobek.setTargetAgent",
          "when": "view == sobekPrompts",
          "group": "1_edit@3"
        },
        {
          "command": "sobek.refinePrompt",
          "when": "view == sobekPrompts",
          "group": "1_edit@4"
        },
        {
          "command": "sobek.showPromptVersions",
          "when": "view == sobekPrompts",
          "group": "2_info@1"
        },
        {
          "command": "sobek.newPromptTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@1"
        },
        {
          "command": "sobek.launchAgentTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@2"
        },
        {
          "command": "sobek.runPromptInAgentTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@3"
        },
        {
          "command": "sobek.showTimeline",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@1"
        },
        {
          "command": "sobek.addWorkflowNote",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@2"
        },
        {
          "command": "sobek.addReviewVerdict",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@3"
        },
        {
          "command": "sobek.changeWorkflowActor",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@4"
        },
        {
          "command": "sobek.completeWorkflow",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@5"
        },
        {
          "command": "sobek.reopenWorkflow",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "2_workflow@6"
        },
        {
          "command": "sobek.archivePrompt",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt",
          "group": "3_danger@1"
        },
        {
          "command": "sobek.deletePrompt",
          "when": "view == sobekPrompts",
          "group": "3_danger@2"
        }
      ],
      "commandPalette": [
        {
          "command": "sobek.openChildPrompt",
          "when": "false"
        },
        {
          "command": "sobek.openPrompt",
          "when": "sobek.hasWorkspace"
        }
      ]
    },
    "configuration": {
      "title": "Sobek",
      "properties": {
        "sobek.terminals.showAgentTerminalOfferAfterChildPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Após criar um prompt filho, oferecer abrir um terminal com o agente alvo já executando o prompt."
        },
        "sobek.ai.model": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "enum": [
            "gemini-3.5-flash",
            "gemini-3.1-pro-preview",
            "gemini-3.1-flash-lite",
            "gemini-2.5-flash",
            "gemini-2.5-pro"
          ],
          "enumDescriptions": [
            "Gemini 3.5 Flash (raciocínio por nível)",
            "Gemini 3.1 Pro Preview (raciocínio por nível)",
            "Gemini 3.1 Flash Lite (raciocínio por nível)",
            "Gemini 2.5 Flash (raciocínio por budget de tokens)",
            "Gemini 2.5 Pro (raciocínio por budget de tokens)"
          ],
          "description": "Modelo Gemini usado no refinamento de prompts e no chat."
        },
        "sobek.ai.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperatura das chamadas Gemini (0 a 2)."
        },
        "sobek.ai.thinkingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilita raciocínio (thinking) nos modelos que permitem desativá-lo."
        },
        "sobek.ai.thinkingLevel": {
          "type": "string",
          "default": "high",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "description": "Nível de raciocínio para modelos Gemini 3.x."
        },
        "sobek.ai.thinkingBudget": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Budget de tokens de raciocínio para modelos Gemini 2.5 (vazio usa um padrão)."
        },
        "sobek.ai.useWorkspaceContext": {
          "type": "boolean",
          "default": false,
          "description": "Injeta README.md, CLAUDE.md, AGENT.md, AGENTS.md, GEMINI.md e .github/copilot-instructions.md da raiz do workspace nas instruções de sistema do Gemini."
        },
        "sobek.ai.includeMentionedFiles": {
          "type": "boolean",
          "default": true,
          "description": "Inclui automaticamente o conteúdo dos arquivos @mencionados no prompt como contexto da IA."
        },
        "sobek.ai.includeLinkedPlan": {
          "type": "boolean",
          "default": true,
          "description": "Inclui o conteúdo do plano vinculado do prompt como contexto da IA."
        },
        "sobek.ai.includeParentPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Ao trabalhar em um prompt filho, inclui o conteúdo do prompt pai como contexto da IA."
        },
        "sobek.ai.includeWorkflowContext": {
          "type": "boolean",
          "default": true,
          "description": "Inclui o estado da tarefa (fase atual, responsável, últimas notas) como contexto da IA."
        },
        "sobek.ai.includeGitContext": {
          "type": "boolean",
          "default": false,
          "description": "Inclui branch atual e últimos commits do repositório como contexto da IA."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.96.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
