{
  "name": "sobek",
  "displayName": "Sobek",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "psielta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/psielta/Sobek.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "prompt",
    "prompt-engineering",
    "claude",
    "codex",
    "gemini",
    "kanban",
    "agents"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sobek",
          "title": "Sobek",
          "icon": "media/sobek.svg"
        }
      ]
    },
    "views": {
      "sobek": [
        {
          "id": "sobekPrompts",
          "name": "%view.prompts%",
          "icon": "media/sobek.svg",
          "contextualTitle": "Sobek"
        },
        {
          "id": "sobekAssistant",
          "type": "webview",
          "name": "%view.assistant%",
          "icon": "media/sobek.svg",
          "contextualTitle": "Sobek"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sobekPrompts",
        "contents": "%welcome.noPrompts%",
        "when": "sobek.hasWorkspace"
      },
      {
        "view": "sobekPrompts",
        "contents": "%welcome.noWorkspace%",
        "when": "!sobek.hasWorkspace"
      }
    ],
    "commands": [
      {
        "command": "sobek.createPrompt",
        "title": "%cmd.createPrompt%",
        "category": "Sobek",
        "icon": "$(add)"
      },
      {
        "command": "sobek.refreshPrompts",
        "title": "%cmd.refreshPrompts%",
        "category": "Sobek",
        "icon": "$(refresh)"
      },
      {
        "command": "sobek.openPrompt",
        "title": "%cmd.openPrompt%",
        "category": "Sobek"
      },
      {
        "command": "sobek.openChildPrompt",
        "title": "%cmd.openChildPrompt%",
        "category": "Sobek"
      },
      {
        "command": "sobek.copyPromptContent",
        "title": "%cmd.copyPromptContent%",
        "category": "Sobek",
        "icon": "$(copy)"
      },
      {
        "command": "sobek.renamePrompt",
        "title": "%cmd.renamePrompt%",
        "category": "Sobek"
      },
      {
        "command": "sobek.setPromptStatus",
        "title": "%cmd.setPromptStatus%",
        "category": "Sobek"
      },
      {
        "command": "sobek.setTargetAgent",
        "title": "%cmd.setTargetAgent%",
        "category": "Sobek"
      },
      {
        "command": "sobek.archivePrompt",
        "title": "%cmd.archivePrompt%",
        "category": "Sobek",
        "icon": "$(archive)"
      },
      {
        "command": "sobek.deletePrompt",
        "title": "%cmd.deletePrompt%",
        "category": "Sobek",
        "icon": "$(trash)"
      },
      {
        "command": "sobek.showPromptVersions",
        "title": "%cmd.showPromptVersions%",
        "category": "Sobek",
        "icon": "$(history)"
      },
      {
        "command": "sobek.generateChildPrompt",
        "title": "%cmd.generateChildPrompt%",
        "category": "Sobek",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "sobek.linkPlan",
        "title": "%cmd.linkPlan%",
        "category": "Sobek",
        "icon": "$(link)"
      },
      {
        "command": "sobek.unlinkPlan",
        "title": "%cmd.unlinkPlan%",
        "category": "Sobek"
      },
      {
        "command": "sobek.newPromptTerminal",
        "title": "%cmd.newPromptTerminal%",
        "category": "Sobek",
        "icon": "$(terminal)"
      },
      {
        "command": "sobek.launchAgentTerminal",
        "title": "%cmd.launchAgentTerminal%",
        "category": "Sobek",
        "icon": "$(robot)"
      },
      {
        "command": "sobek.runPromptInAgentTerminal",
        "title": "%cmd.runPromptInAgentTerminal%",
        "category": "Sobek",
        "icon": "$(play)"
      },
      {
        "command": "sobek.newWorkspaceTerminal",
        "title": "%cmd.newWorkspaceTerminal%",
        "category": "Sobek"
      },
      {
        "command": "sobek.openBoard",
        "title": "%cmd.openBoard%",
        "category": "Sobek",
        "icon": "$(layout-panel-justify)"
      },
      {
        "command": "sobek.startWorkflow",
        "title": "%cmd.startWorkflow%",
        "category": "Sobek"
      },
      {
        "command": "sobek.addWorkflowNote",
        "title": "%cmd.addWorkflowNote%",
        "category": "Sobek"
      },
      {
        "command": "sobek.addReviewVerdict",
        "title": "%cmd.addReviewVerdict%",
        "category": "Sobek"
      },
      {
        "command": "sobek.changeWorkflowActor",
        "title": "%cmd.changeWorkflowActor%",
        "category": "Sobek"
      },
      {
        "command": "sobek.completeWorkflow",
        "title": "%cmd.completeWorkflow%",
        "category": "Sobek"
      },
      {
        "command": "sobek.reopenWorkflow",
        "title": "%cmd.reopenWorkflow%",
        "category": "Sobek"
      },
      {
        "command": "sobek.showTimeline",
        "title": "%cmd.showTimeline%",
        "category": "Sobek",
        "icon": "$(list-ordered)"
      },
      {
        "command": "sobek.refinePrompt",
        "title": "%cmd.refinePrompt%",
        "category": "Sobek",
        "icon": "$(sparkle)"
      },
      {
        "command": "sobek.setGeminiApiKey",
        "title": "%cmd.setGeminiApiKey%",
        "category": "Sobek"
      },
      {
        "command": "sobek.refreshAgentUsage",
        "title": "%cmd.refreshAgentUsage%",
        "category": "Sobek",
        "icon": "$(pulse)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sobek.createPrompt",
          "when": "view == sobekPrompts",
          "group": "navigation@1"
        },
        {
          "command": "sobek.openBoard",
          "when": "view == sobekPrompts",
          "group": "navigation@2"
        },
        {
          "command": "sobek.refreshPrompts",
          "when": "view == sobekPrompts",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "sobek.copyPromptContent",
          "when": "view == sobekPrompts",
          "group": "inline@1"
        },
        {
          "command": "sobek.generateChildPrompt",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "inline@2"
        },
        {
          "command": "sobek.linkPlan",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt-noplan",
          "group": "inline@3"
        },
        {
          "command": "sobek.archivePrompt",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "inline@4"
        },
        {
          "command": "sobek.deletePrompt",
          "when": "view == sobekPrompts",
          "group": "inline@5"
        },
        {
          "command": "sobek.generateChildPrompt",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "0_generate@1"
        },
        {
          "command": "sobek.linkPlan",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt-noplan",
          "group": "0_generate@2"
        },
        {
          "command": "sobek.unlinkPlan",
          "when": "view == sobekPrompts && viewItem == sobekRootPrompt-plan",
          "group": "0_generate@3"
        },
        {
          "command": "sobek.renamePrompt",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "1_edit@1"
        },
        {
          "command": "sobek.setPromptStatus",
          "when": "view == sobekPrompts",
          "group": "1_edit@2"
        },
        {
          "command": "sobek.setTargetAgent",
          "when": "view == sobekPrompts",
          "group": "1_edit@3"
        },
        {
          "command": "sobek.refinePrompt",
          "when": "view == sobekPrompts",
          "group": "1_edit@4"
        },
        {
          "command": "sobek.showPromptVersions",
          "when": "view == sobekPrompts",
          "group": "2_info@1"
        },
        {
          "command": "sobek.newPromptTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@1"
        },
        {
          "command": "sobek.launchAgentTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@2"
        },
        {
          "command": "sobek.runPromptInAgentTerminal",
          "when": "view == sobekPrompts",
          "group": "2_terminal@3"
        },
        {
          "command": "sobek.showTimeline",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@1"
        },
        {
          "command": "sobek.addWorkflowNote",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@2"
        },
        {
          "command": "sobek.addReviewVerdict",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@3"
        },
        {
          "command": "sobek.changeWorkflowActor",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@4"
        },
        {
          "command": "sobek.completeWorkflow",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@5"
        },
        {
          "command": "sobek.reopenWorkflow",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "2_workflow@6"
        },
        {
          "command": "sobek.archivePrompt",
          "when": "view == sobekPrompts && viewItem =~ /^sobekRootPrompt/",
          "group": "3_danger@1"
        },
        {
          "command": "sobek.deletePrompt",
          "when": "view == sobekPrompts",
          "group": "3_danger@2"
        }
      ],
      "commandPalette": [
        {
          "command": "sobek.openChildPrompt",
          "when": "false"
        },
        {
          "command": "sobek.openPrompt",
          "when": "sobek.hasWorkspace"
        }
      ]
    },
    "configuration": {
      "title": "Sobek",
      "properties": {
        "sobek.terminals.showAgentTerminalOfferAfterChildPrompt": {
          "type": "boolean",
          "default": true,
          "description": "%config.showAgentTerminalOffer%"
        },
        "sobek.ai.model": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "enum": [
            "gemini-3.5-flash",
            "gemini-3.1-pro-preview",
            "gemini-3.1-flash-lite",
            "gemini-2.5-flash",
            "gemini-2.5-pro"
          ],
          "description": "%config.aiModel%"
        },
        "sobek.ai.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "%config.aiTemperature%"
        },
        "sobek.ai.thinkingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.aiThinkingEnabled%"
        },
        "sobek.ai.thinkingLevel": {
          "type": "string",
          "default": "high",
          "enum": ["minimal", "low", "medium", "high"],
          "description": "%config.aiThinkingLevel%"
        },
        "sobek.ai.thinkingBudget": {
          "type": ["number", "null"],
          "default": null,
          "description": "%config.aiThinkingBudget%"
        },
        "sobek.ai.useWorkspaceContext": {
          "type": "boolean",
          "default": false,
          "description": "%config.aiUseWorkspaceContext%"
        },
        "sobek.ai.includeMentionedFiles": {
          "type": "boolean",
          "default": true,
          "description": "%config.aiIncludeMentionedFiles%"
        },
        "sobek.ai.includeLinkedPlan": {
          "type": "boolean",
          "default": true,
          "description": "%config.aiIncludeLinkedPlan%"
        },
        "sobek.ai.includeParentPrompt": {
          "type": "boolean",
          "default": true,
          "description": "%config.aiIncludeParentPrompt%"
        },
        "sobek.ai.includeWorkflowContext": {
          "type": "boolean",
          "default": true,
          "description": "%config.aiIncludeWorkflowContext%"
        },
        "sobek.ai.includeGitContext": {
          "type": "boolean",
          "default": false,
          "description": "%config.aiIncludeGitContext%"
        },
        "sobek.usage.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.usageEnabled%"
        },
        "sobek.usage.claudeCredentialsPath": {
          "type": "string",
          "default": "",
          "description": "%config.usageClaudePath%"
        },
        "sobek.usage.codexSessionsPath": {
          "type": "string",
          "default": "",
          "description": "%config.usageCodexPath%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.96.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
